<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container" style="max-width: 800px;">
      <%- include('../partials/flash') %>
      
      <div class="card" style="text-align: center;">
        <%- include('../partials/avatar', {name: profileUser.name, size: 'lg'}) %>
        <h1 style="margin-top: 16px;"><%= profileUser.name %></h1>
        <% if (profileUser.role === 'sound_student' && profileUser.primary_position) { %>
          <p style="color: var(--accent-primary); font-weight: 600; font-size: 18px;"><%= profileUser.primary_position %></p>
        <% } else { %>
          <p style="color: var(--text-secondary); text-transform: capitalize;"><%= profileUser.role.replace('_', ' ') %></p>
        <% } %>
        
        <% if (profileUser.specializations && profileUser.specializations.length > 0) { %>
          <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 12px;">
            <% profileUser.specializations.forEach(spec => { %>
              <span class="badge badge-info"><%= spec %></span>
            <% }) %>
          </div>
        <% } %>
        
        <% if (profileUser.bio) { %>
          <p style="margin-top: 24px; color: var(--text-primary);"><%= profileUser.bio %></p>
        <% } %>
        
        <div class="card-meta" style="justify-content: center; margin-top: 16px;">
          <% if (profileUser.year) { %>
            <span>Class of <%= profileUser.year %></span>
            <span>•</span>
          <% } %>
          <span>Joined <%= new Date(profileUser.created_at).toLocaleDateString() %></span>
        </div>
        
        <% if (user.id === profileUser.id) { %>
          <a href="/users/<%= profileUser.id %>/edit" class="btn btn-primary" style="margin-top: 24px;">Edit Profile</a>
        <% } %>
      </div>
      
      <a href="/users" class="btn btn-secondary" style="margin-top: 24px;">← Back to Directory</a>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>