<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container" style="max-width: 800px;">
      <%- include('../partials/flash') %>
      
      <div class="card">
        <div class="card-header">
          <div>
            <h1 class="card-title"><%= request.title %></h1>
            <div class="card-meta">
              <span>Posted by <%= request.poster_name %></span>
              <span>•</span>
              <span><%= new Date(request.created_at).toLocaleDateString() %></span>
              <% if (request.project_type) { %>
                <span>•</span>
                <span><%= request.project_type %></span>
              <% } %>
            </div>
          </div>
          <span class="status-indicator <%= request.status === 'open' ? 'status-open' : 'status-claimed' %>">
            <%= request.status === 'open' ? 'Open' : 'Claimed' %>
          </span>
        </div>
        
        <div class="card-content">
          <p style="white-space: pre-wrap; color: var(--text-primary);"><%= request.description %></p>
        </div>
        
        <div class="card-footer">
          <div class="card-tags">
            <span class="badge badge-primary"><%= request.position_needed.replace(/_/g, ' ') %></span>
            <% if (request.tags && request.tags.length > 0) { %>
              <% request.tags.forEach(tag => { %>
                <span class="badge badge-secondary"><%= tag.replace(/_/g, ' ') %></span>
              <% }) %>
            <% } %>
          </div>
        </div>
        
        <% if (request.shoot_date) { %>
          <p style="margin-top: 16px;"><strong>Shoot Date:</strong> <%= new Date(request.shoot_date).toLocaleDateString() %></p>
        <% } %>
        
        <% if (request.status === 'claimed' && request.claimer_name) { %>
          <p style="margin-top: 16px; padding: 12px; background-color: var(--bg-secondary); border-radius: 4px;">
            <strong>Claimed by:</strong> <%= request.claimer_name %>
          </p>
        <% } %>
        
        <div style="margin-top: 24px; display: flex; gap: 12px;">
          <% if (user.role === 'sound_student' && request.status === 'open') { %>
            <form method="POST" action="/requests/<%= request.id %>/claim">
              <button type="submit" class="btn btn-primary">Claim This Request</button>
            </form>
          <% } %>
          
          <% if ((user.id === request.claimed_by || user.role === 'admin') && request.status === 'claimed') { %>
            <form method="POST" action="/requests/<%= request.id %>/unclaim">
              <button type="submit" class="btn btn-secondary">Unclaim</button>
            </form>
          <% } %>
          
          <% if (user.id === request.posted_by || user.role === 'admin') { %>
            <form method="POST" action="/requests/<%= request.id %>?_method=DELETE">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          <% } %>
        </div>
      </div>
      
      <a href="/requests" class="btn btn-secondary" style="margin-top: 24px;">← Back to Requests</a>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>