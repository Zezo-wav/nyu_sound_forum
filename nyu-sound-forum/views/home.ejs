<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NYU Sound Forum</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/nav') %>
  
  <main>
    <div class="container">
      <%- include('partials/flash') %>
      
      <% if (!user) { %>
        <div class="text-center" style="padding: 80px 20px;">
          <h1 style="font-size: 36px; margin-bottom: 16px;">NYU Sound Forum</h1>
          <p style="font-size: 18px; color: var(--text-secondary); margin-bottom: 32px;">
            Connect sound students with directors and producers
          </p>
          <div style="display: flex; gap: 16px; justify-content: center;">
            <a href="/auth/register" class="btn btn-primary">Get Started</a>
            <a href="/auth/login" class="btn btn-secondary">Login</a>
          </div>
        </div>
      <% } else { %>
        <h1>Welcome back, <%= user.name %>! </h1>
        
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value"></div>
            <div class="stat-label">Browse Requests</div>
            <a href="/requests" class="btn btn-secondary btn-sm" style="margin-top: 12px;">View All</a>
          </div>
          
          <div class="stat-card">
            <div class="stat-value"></div>
            <div class="stat-label">Forum Discussions</div>
            <a href="/forum" class="btn btn-secondary btn-sm" style="margin-top: 12px;">Join Conversation</a>
          </div>
          
          <div class="stat-card">
            <div class="stat-value"></div>
            <div class="stat-label">Knowledge Base</div>
            <a href="/wiki" class="btn btn-secondary btn-sm" style="margin-top: 12px;">Learn More</a>
          </div>
          
          <div class="stat-card">
            <div class="stat-value"></div>
            <div class="stat-label">User Directory</div>
            <a href="/users" class="btn btn-secondary btn-sm" style="margin-top: 12px;">Find People</a>
          </div>
        </div>

        <div style="margin-top: 40px;">
          <h2>Quick Actions</h2>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <% if (user.role === 'director' || user.role === 'producer') { %>
              <a href="/requests/new" class="btn btn-primary">Post New Request</a>
              <a href="/requests/my/posted" class="btn btn-secondary">My Requests</a>
            <% } %>
            
            <% if (user.role === 'sound_student') { %>
              <a href="/requests?status=open" class="btn btn-primary">Find Work</a>
              <a href="/gigs/new" class="btn btn-primary">Post a Gig</a>
              <a href="/requests/my/claimed" class="btn btn-secondary">My Claimed Requests</a>
              <a href="/gigs" class="btn btn-secondary">Browse Gigs</a>
            <% } %>
            
            <a href="/forum/new" class="btn btn-secondary">Ask a Question</a>
            <a href="/search" class="btn btn-secondary">Search</a>
          </div>
        </div>
      <% } %>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
