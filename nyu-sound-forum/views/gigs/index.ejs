<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container">
      <%- include('../partials/flash') %>
      
      <div style="background: var(--accent-light); border: 1px solid var(--accent-primary); border-radius: 6px; padding: 16px; margin-bottom: 24px;">
        <h3 style="margin: 0 0 8px 0; color: var(--accent-primary);">Sound Gigs Board</h3>
        <p style="margin: 0; font-size: 14px; color: var(--text-primary);">
          This is where sound students post jobs when they need help on their own projects. 
          Got a gig and need a boom op, mixer, or sound designer? Post it here!
        </p>
      </div>
      
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1>Sound Gigs</h1>
        <% if (user.role === 'sound_student') { %>
          <a href="/gigs/new" class="btn btn-primary">Post Gig</a>
        <% } %>
      </div>
      
      <div class="filters">
        <form method="GET" action="/gigs" style="display: flex; gap: 12px; width: 100%; flex-wrap: wrap;">
          <select name="position" onchange="this.form.submit()">
            <option value="">All Positions</option>
            <option value="sound_mixer" <%= filters.position === 'sound_mixer' ? 'selected' : '' %>>Sound Mixer</option>
            <option value="boom_operator" <%= filters.position === 'boom_operator' ? 'selected' : '' %>>Boom Operator</option>
            <option value="sound_designer" <%= filters.position === 'sound_designer' ? 'selected' : '' %>>Sound Designer</option>
            <option value="dialogue_editor" <%= filters.position === 'dialogue_editor' ? 'selected' : '' %>>Dialogue Editor</option>
            <option value="foley_artist" <%= filters.position === 'foley_artist' ? 'selected' : '' %>>Foley Artist</option>
            <option value="adr_engineer" <%= filters.position === 'adr_engineer' ? 'selected' : '' %>>ADR Engineer</option>
            <option value="mixing_engineer" <%= filters.position === 'mixing_engineer' ? 'selected' : '' %>>Mixing Engineer</option>
          </select>
          <select name="sort" onchange="this.form.submit()">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
            <option value="earliest_date" <%= filters.sort === 'earliest_date' ? 'selected' : '' %>>Earliest Date</option>
            <option value="latest_date" <%= filters.sort === 'latest_date' ? 'selected' : '' %>>Latest Date</option>
          </select>
          <select name="status" onchange="this.form.submit()">
            <option value="">All Status</option>
            <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
            <option value="filled" <%= filters.status === 'filled' ? 'selected' : '' %>>Filled</option>
          </select>
          <select name="tag" onchange="this.form.submit()">
            <option value="">All Tags</option>
            <option value="urgent" <%= filters.tag === 'urgent' ? 'selected' : '' %>>Urgent</option>
            <option value="paid" <%= filters.tag === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="student_film" <%= filters.tag === 'student_film' ? 'selected' : '' %>>Student Film</option>
            <option value="thesis" <%= filters.tag === 'thesis' ? 'selected' : '' %>>Thesis</option>
          </select>
        </form>
      </div>
      
      <% if (gigs.length === 0) { %>
        <p style="text-align: center; color: var(--text-secondary); margin-top: 40px;">No gigs posted yet.</p>
        <% if (user.role === 'sound_student') { %>
          <div style="text-align: center; margin-top: 16px;">
            <a href="/gigs/new" class="btn btn-primary">Post the First Gig!</a>
          </div>
        <% } %>
      <% } else { %>
        <% gigs.forEach(gig => { %>
          <div class="card">
            <div class="card-header">
              <div>
                <h3 class="card-title"><a href="/gigs/<%= gig.id %>"><%= gig.title %></a></h3>
                <div class="card-meta">
                  <span><%- include('../partials/avatar', {name: gig.poster_name, size: 'sm'}) %> <%= gig.poster_name %></span>
                  <% if (gig.poster_specializations && gig.poster_specializations.length > 0) { %>
                    <span class="badge badge-sm badge-info"><%= gig.poster_specializations[0] %></span>
                  <% } %>
                  <span>•</span>
                  <span><%= new Date(gig.created_at).toLocaleDateString() %></span>
                  <% if (gig.project_type) { %>
                    <span>•</span>
                    <span><%= gig.project_type %></span>
                  <% } %>
                </div>
              </div>
              <span class="status-indicator <%= gig.status === 'open' ? 'status-open' : 'status-claimed' %>">
                <%= gig.status === 'open' ? '✓ Open' : '⚡ Filled' %>
              </span>
            </div>
            <p class="card-content"><%= gig.description.substring(0, 200) %>...</p>
            <div class="card-footer">
              <div class="card-tags">
                <span class="badge badge-primary"><%= gig.position_needed.replace(/_/g, ' ') %></span>
                <% if (gig.tags && gig.tags.length > 0) { %>
                  <% gig.tags.forEach(tag => { %>
                    <span class="badge badge-secondary"><%= tag.replace(/_/g, ' ') %></span>
                  <% }) %>
                <% } %>
              </div>
              <a href="/gigs/<%= gig.id %>" class="btn btn-sm btn-secondary">View Details →</a>
            </div>
          </div>
        <% }) %>
      <% } %>
      
      <% if (user.role === 'sound_student') { %>
        <div style="margin-top: 32px; display: flex; gap: 12px;">
          <a href="/gigs/my/posted" class="btn btn-secondary">My Posted Gigs</a>
          <a href="/gigs/my/filled" class="btn btn-secondary">Gigs I Filled</a>
        </div>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>