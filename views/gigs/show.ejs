<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container" style="max-width: 800px;">
      <%- include('../partials/flash') %>
      
      <div class="card">
        <div class="card-header">
          <div>
            <h1 class="card-title"><%= gig.title %></h1>
            <div class="card-meta">
              <span><%- include('../partials/avatar', {name: gig.poster_name, size: 'sm'}) %> <%= gig.poster_name %></span>
              <% if (gig.poster_specializations && gig.poster_specializations.length > 0) { %>
                <% gig.poster_specializations.slice(0, 2).forEach(spec => { %>
                  <span class="badge badge-sm badge-info"><%= spec %></span>
                <% }) %>
              <% } %>
              <span>•</span>
              <span><%= new Date(gig.created_at).toLocaleDateString() %></span>
              <% if (gig.project_type) { %>
                <span>•</span>
                <span><%= gig.project_type %></span>
              <% } %>
            </div>
          </div>
          <span class="status-indicator <%= gig.status === 'open' ? 'status-open' : 'status-claimed' %>">
            <%= gig.status === 'open' ? 'Open' : 'Filled' %>
          </span>
        </div>
        
        <div class="card-content">
          <p style="white-space: pre-wrap; color: var(--text-primary);"><%= gig.description %></p>
        </div>
        
        <div class="card-footer">
          <div class="card-tags">
            <span class="badge badge-primary"><%= gig.position_needed.replace(/_/g, ' ') %></span>
            <% if (gig.tags && gig.tags.length > 0) { %>
              <% gig.tags.forEach(tag => { %>
                <span class="badge badge-secondary"><%= tag.replace(/_/g, ' ') %></span>
              <% }) %>
            <% } %>
          </div>
        </div>
        
        <% if (gig.date_needed) { %>
          <p style="margin-top: 16px;"><strong>Date Needed:</strong> <%= new Date(gig.date_needed).toLocaleDateString() %></p>
        <% } %>
        
        <% if (gig.status === 'filled' && gig.filler_name) { %>
          <p style="margin-top: 16px; padding: 12px; background-color: var(--bg-secondary); border-radius: 4px;">
            <strong>Filled by:</strong> <%= gig.filler_name %>
          </p>
        <% } %>
        
        <div style="margin-top: 24px; display: flex; gap: 12px;">
          <% if (user.role === 'sound_student' && gig.status === 'open' && user.id !== gig.posted_by) { %>
            <form method="POST" action="/gigs/<%= gig.id %>/fill">
              <button type="submit" class="btn btn-primary">Fill This Gig</button>
            </form>
          <% } %>
          
          <% if ((user.id === gig.filled_by || user.id === gig.posted_by || user.role === 'admin') && gig.status === 'filled') { %>
            <form method="POST" action="/gigs/<%= gig.id %>/unfill">
              <button type="submit" class="btn btn-secondary">Unfill</button>
            </form>
          <% } %>
          
          <% if (user.id === gig.posted_by || user.role === 'admin') { %>
            <form method="POST" action="/gigs/<%= gig.id %>?_method=DELETE">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          <% } %>
        </div>
      </div>
      
      <a href="/gigs" class="btn btn-secondary" style="margin-top: 24px;">← Back to Gigs</a>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>