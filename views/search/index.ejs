<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container">
      <%- include('../partials/flash') %>
      <h1>Search</h1>
      <form method="GET" action="/search" class="search-bar" style="max-width: 100%;">
        <input type="text" name="q" placeholder="Search requests, forum posts, wiki pages..." value="<%= query %>" autofocus>
      </form>
      
      <% if (query) { %>
        <h2 style="margin-top: 32px;">Results for "<%= query %>"</h2>
        
        <% if (results.requests.length > 0) { %>
          <h3>Requests (<%= results.requests.length %>)</h3>
          <% results.requests.forEach(request => { %>
            <div class="card">
              <h3 class="card-title"><a href="/requests/<%= request.id %>"><%= request.title %></a></h3>
              <p class="card-content"><%= request.description.substring(0, 150) %>...</p>
            </div>
          <% }) %>
        <% } %>
        
        <% if (results.gigs.length > 0) { %>
          <h3 style="margin-top: 24px;">Sound Gigs (<%= results.gigs.length %>)</h3>
          <% results.gigs.forEach(gig => { %>
            <div class="card">
              <h3 class="card-title"><a href="/gigs/<%= gig.id %>"><%= gig.title %></a></h3>
              <p class="card-content"><%= gig.description.substring(0, 150) %>...</p>
            </div>
          <% }) %>
        <% } %>
        
        <% if (results.posts.length > 0) { %>
          <h3 style="margin-top: 24px;">Forum Posts (<%= results.posts.length %>)</h3>
          <% results.posts.forEach(post => { %>
            <div class="card">
              <h3 class="card-title"><a href="/forum/<%= post.id %>"><%= post.title %></a></h3>
              <p class="card-content"><%= post.content.substring(0, 150) %>...</p>
            </div>
          <% }) %>
        <% } %>
        
        <% if (results.wiki.length > 0) { %>
          <h3 style="margin-top: 24px;">Wiki Pages (<%= results.wiki.length %>)</h3>
          <% results.wiki.forEach(page => { %>
            <div class="card">
              <h3 class="card-title"><a href="/wiki/<%= page.slug %>"><%= page.title %></a></h3>
            </div>
          <% }) %>
        <% } %>
        
        <% if (results.requests.length === 0 && results.gigs.length === 0 && results.posts.length === 0 && results.wiki.length === 0) { %>
          <p style="text-align: center; color: var(--text-secondary); margin-top: 40px;">No results found.</p>
        <% } %>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
