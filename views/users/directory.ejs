<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container">
      <%- include('../partials/flash') %>
      <h1>Sound Student Directory</h1>
      <p style="color: var(--text-secondary); margin-bottom: 32px;">
        Connect with NYU Tisch sound students by their primary position
      </p>
      
      <% const positions = Object.keys(grouped).sort(); %>
      <% positions.forEach((position, index) => { %>
        <div style="margin-bottom: 40px;">
          <h2 style="color: var(--accent-primary); margin-bottom: 16px; cursor: pointer; display: flex; align-items: center; gap: 8px;" onclick="toggleSection('<%= position.replace(/\s+/g, '-') %>')">
            <span id="arrow-<%= position.replace(/\s+/g, '-') %>" style="transition: transform 0.2s;">▼</span>
            <%= position %> (<%= grouped[position].length %>)
          </h2>
          
          <div id="section-<%= position.replace(/\s+/g, '-') %>" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
            <% grouped[position].forEach(u => { %>
              <a href="/users/<%= u.id %>" style="text-decoration: none;">
                <div class="card user-card" style="flex-direction: column; text-align: center; cursor: pointer;">
                  <%- include('../partials/avatar', {name: u.name, size: 'lg'}) %>
                  <div style="margin-top: 12px;">
                    <h4 style="margin-bottom: 4px;"><%= u.name %></h4>
                    <p style="color: var(--text-secondary); font-size: 13px;">
                      <%= u.primary_position || 'Sound Student' %>
                    </p>
                    <% if (u.specializations && u.specializations.length > 0) { %>
                      <div style="display: flex; gap: 4px; flex-wrap: wrap; justify-content: center; margin-top: 8px;">
                        <% u.specializations.slice(0, 2).forEach(spec => { %>
                          <span class="badge badge-sm badge-secondary"><%= spec %></span>
                        <% }) %>
                      </div>
                    <% } %>
                    <% if (u.year) { %>
                      <p style="color: var(--text-tertiary); font-size: 12px; margin-top: 6px;">
                        Class of <%= u.year %>
                      </p>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
      
      <% if (users.length === 0) { %>
        <p style="text-align: center; color: var(--text-secondary); margin-top: 40px;">
          No sound students in the directory yet.
        </p>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
  <script>
    function toggleSection(position) {
      const section = document.getElementById('section-' + position);
      const arrow = document.getElementById('arrow-' + position);
      
      if (section.style.display === 'none') {
        section.style.display = 'grid';
        arrow.style.transform = 'rotate(0deg)';
      } else {
        section.style.display = 'none';
        arrow.style.transform = 'rotate(-90deg)';
      }
    }
  </script>
</body>
</html>