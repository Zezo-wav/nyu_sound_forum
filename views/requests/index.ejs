<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main>
    <div class="container">
      <%- include('../partials/flash') %>
      
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1>Browse Requests</h1>
        <% if (user.role === 'director' || user.role === 'producer') { %>
          <a href="/requests/new" class="btn btn-primary">Post Request</a>
        <% } %>
      </div>
      
      <div class="filters">
        <form method="GET" action="/requests" style="display: flex; gap: 12px; width: 100%; flex-wrap: wrap;">
          <select name="position" onchange="this.form.submit()">
            <option value="">All Positions</option>
            <option value="sound_mixer" <%= filters.position === 'sound_mixer' ? 'selected' : '' %>>Sound Mixer</option>
            <option value="boom_operator" <%= filters.position === 'boom_operator' ? 'selected' : '' %>>Boom Operator</option>
            <option value="sound_designer" <%= filters.position === 'sound_designer' ? 'selected' : '' %>>Sound Designer</option>
            <option value="dialogue_editor" <%= filters.position === 'dialogue_editor' ? 'selected' : '' %>>Dialogue Editor</option>
            <option value="any_production" <%= filters.position === 'any_production' ? 'selected' : '' %>>Any Production</option>
            <option value="any_post" <%= filters.position === 'any_post' ? 'selected' : '' %>>Any Post</option>
          </select>
          <select name="sort" onchange="this.form.submit()">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
            <option value="earliest_date" <%= filters.sort === 'earliest_date' ? 'selected' : '' %>>Earliest Date</option>
            <option value="latest_date" <%= filters.sort === 'latest_date' ? 'selected' : '' %>>Latest Date</option>
          </select>
          <select name="status" onchange="this.form.submit()">
            <option value="">All Status</option>
            <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
            <option value="claimed" <%= filters.status === 'claimed' ? 'selected' : '' %>>Claimed</option>
          </select>
          <select name="tag" onchange="this.form.submit()">
            <option value="">All Tags</option>
            <option value="urgent" <%= filters.tag === 'urgent' ? 'selected' : '' %>>Urgent</option>
            <option value="paid" <%= filters.tag === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="student_film" <%= filters.tag === 'student_film' ? 'selected' : '' %>>Student Film</option>
            <option value="thesis" <%= filters.tag === 'thesis' ? 'selected' : '' %>>Thesis</option>
          </select>
        </form>
      </div>
      
      <% if (requests.length === 0) { %>
        <p style="text-align: center; color: var(--text-secondary); margin-top: 40px;">No requests found.</p>
      <% } else { %>
        <% requests.forEach(request => { %>
          <div class="card">
            <div class="card-header">
              <div>
                <h3 class="card-title"><a href="/requests/<%= request.id %>"><%= request.title %></a></h3>
                <div class="card-meta">
                  <span>Posted by <%= request.poster_name %></span>
                  <span>•</span>
                  <span><%= new Date(request.created_at).toLocaleDateString() %></span>
                  <% if (request.project_type) { %>
                    <span>•</span>
                    <span><%= request.project_type %></span>
                  <% } %>
                </div>
              </div>
              <span class="status-indicator <%= request.status === 'open' ? 'status-open' : 'status-claimed' %>">
                <%= request.status === 'open' ? '✓ Open' : '⚡ Claimed' %>
              </span>
            </div>
            <p class="card-content"><%= request.description.substring(0, 200) %>...</p>
            <div class="card-footer">
              <div class="card-tags">
                <span class="badge badge-primary"><%= request.position_needed.replace('_', ' ') %></span>
                <% if (request.tags && request.tags.length > 0) { %>
                  <% request.tags.forEach(tag => { %>
                    <span class="badge badge-secondary"><%= tag.replace('_', ' ') %></span>
                  <% }) %>
                <% } %>
              </div>
              <a href="/requests/<%= request.id %>" class="btn btn-sm btn-secondary">View Details →</a>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
